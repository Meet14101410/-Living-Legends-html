<!DOCTYPE html>
<html>
<head>
  <title>Living Legends</title>
</head>
<body style="font-family:Arial; text-align:center; background:#e8f5e9;">

  <h1>🌿 Living Legends 🌿</h1>
  <p id="question">Loading...</p>

  <button onclick="checkAnswer('a')">Plant</button>
  <button onclick="checkAnswer('b')">Animal</button>

  <p id="result"></p>

  <script>
    let q = {
      text: "Which of these produces its own food?",
      answer: "a"
    };

    document.getElementById("question").innerText = q.text;

    function checkAnswer(choice) {
      if(choice === q.answer) {
        document.getElementById("result").innerText = "✅ Correct!";
      } else {
        document.getElementById("result").innerText = "❌ Try Again!";
      }
    }
  </script>

</body>
</html>
