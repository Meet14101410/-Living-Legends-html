const questions = [
  { q: "Which of these produces its own food?", a: "Plant" },
  { q: "Which is known as the powerhouse of the cell?", a: "Mitochondria" },
  { q: "Which organ pumps blood?", a: "Heart" }
];

let index = 0;
let score = 0;

function loadQuestion() {
  document.getElementById("question").innerText = questions[index].q;
}

function checkAnswer(answer) {
  if (answer === questions[index].a) {
    score++;
    document.getElementById("result").innerText = "✅ Correct!";
  } else {
    document.getElementById("result").innerText = "❌ Wrong!";
  }

  index++;

  setTimeout(() => {
    if (index < questions.length) {
      loadQuestion();
      document.getElementById("result").innerText = "";
    } else {
      document.getElementById("question").innerText = "Game Over! Score: " + score;
    }
  }, 1000);
}

loadQuestion();
